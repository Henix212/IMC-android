<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/ic_connectionbackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16sp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16sp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="48sp"
                android:layout_height="48sp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_back"
                android:contentDescription="@string/btn_back_description"
                app:tint="@color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="@string/title_imc"
                android:textColor="@color/white"
                android:textSize="28sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btnEmail"
                    android:layout_width="48sp"
                    android:layout_height="48sp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_email"
                    android:contentDescription="@string/btn_email_description"
                    app:tint="@color/white" />

                <ImageButton
                    android:id="@+id/btnCalendar"
                    android:layout_width="48sp"
                    android:layout_height="48sp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_calendar"
                    android:contentDescription="@string/btn_calendar_description"
                    app:tint="@color/white" />
            </LinearLayout>
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/transparent_card"
            android:orientation="vertical"
            android:padding="24sp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:baselineAligned="false">

                <LinearLayout
                    android:layout_width="0sp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8sp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_genre"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:layout_marginBottom="4sp"/>

                    <Spinner
                        android:id="@+id/spinnerGenre"
                        android:layout_width="match_parent"
                        android:layout_height="48sp"
                        android:background="@drawable/rounded_corner"
                        android:backgroundTint="#4DFFFFFF"
                        android:padding="8sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0sp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_birthdate"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:layout_marginBottom="4sp"/>

                    <EditText
                        android:id="@+id/etBirthDate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/hint_date_format"
                        android:textColor="@color/white"
                        android:textColorHint="#B3FFFFFF"
                        android:backgroundTint="@color/white"
                        android:inputType="date"
                        android:autofillHints="none"
                        android:textSize="16sp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16sp"
                android:text="@string/label_poids"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etPoids"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/white"
                android:inputType="numberDecimal"
                android:textColor="@color/white"
                android:autofillHints="none" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16sp"
                android:text="@string/label_taille"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etTaille"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/white"
                android:inputType="numberDecimal"
                android:textColor="@color/white"
                android:autofillHints="none" />

            <RadioGroup
                android:id="@+id/rgUnit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="8sp">

                <RadioButton
                    android:id="@+id/rbMetre"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_metre"
                    android:textColor="@color/white"
                    android:buttonTint="@color/white" />

                <RadioButton
                    android:id="@+id/rbCm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_cm"
                    android:checked="true"
                    android:textColor="@color/white"
                    android:buttonTint="@color/white" />
            </RadioGroup>

            <CheckBox
                android:id="@+id/cbAffichage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_affichage"
                android:textColor="@color/white"
                android:buttonTint="@color/white"
                android:checked="false"
                android:layout_marginTop="8sp" />

            <LinearLayout
                android:id="@+id/resultArea"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16sp"
                android:background="#26FFFFFF"
                android:orientation="vertical"
                android:padding="16sp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_resultat"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvResultText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8sp"
                    android:text="@string/result_initial_text"
                    android:textColor="@color/white"
                    android:textStyle="italic" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24sp"
                android:orientation="horizontal"
                android:weightSum="2"
                style="?android:attr/buttonBarStyle">

                <Button
                    android:id="@+id/btnCalculer"
                    android:layout_width="0sp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="4sp"
                    android:backgroundTint="@color/white"
                    android:text="@string/btn_calculer"
                    android:textColor="@color/black"
                    app:cornerRadius="12sp"
                    style="?android:attr/buttonBarButtonStyle" />

                <Button
                    android:id="@+id/btnRAZ"
                    android:layout_width="0sp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4sp"
                    android:backgroundTint="#B3FFFFFF"
                    android:text="@string/btn_raz"
                    android:textColor="@color/black"
                    app:cornerRadius="12sp"
                    style="?android:attr/buttonBarButtonStyle" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</ScrollView>